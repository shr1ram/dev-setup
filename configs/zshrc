# Guard: only source this in zsh or bash
if [ -z "$ZSH_VERSION" ] && [ -z "$BASH_VERSION" ]; then
    return 2>/dev/null || exit 0
fi

export PATH="$HOME/.local/bin:$PATH"

# Claude Code: fullscreen / no-flicker mode (alternate screen buffer)
export CLAUDE_CODE_NO_FLICKER=1

# nvm initialization
if [ -d "$HOME/.nvm" ]; then
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
fi

# pyenv initialization
if command -v pyenv &>/dev/null; then
    export PYENV_ROOT="$HOME/.pyenv"
    [[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init - zsh)"
fi

# Enable Zsh completion system
if [ -n "$ZSH_VERSION" ]; then
    autoload -Uz compinit
    compinit
fi

# Aliases
alias crc='tmux new-session -s claude$(($(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -c "^claude") + 1)) \; set destroy-unattached on \; send-keys "claude --remote-control" Enter'
